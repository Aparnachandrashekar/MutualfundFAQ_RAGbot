# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env — it is gitignored.

# Groq API key (required when running Phase 3 with --use-llm)
# Get one at: https://console.groq.com/keys
GROQ_API_KEY=

# Optional: override the default Groq model
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: enable Groq LLM automatically when GROQ_API_KEY is set
# USE_LLM=true

# Phase 3 HTTP API (for Phase 4 UI)
# API_HOST=0.0.0.0
# API_PORT=8000
# PHASE2_DIR=data/phase2_results
